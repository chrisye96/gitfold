{
  "manifest_version": 3,
  "name": "GitFold — Download GitHub Folders",
  "version": "1.0.0",
  "description": "Download any GitHub directory as a zip. One click, no clone.",

  "permissions": [
    "storage",
    "downloads"
  ],

  "host_permissions": [
    "https://github.com/*"
  ],

  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },

  "content_scripts": [{
    "matches": ["https://github.com/*"],
    "js": ["dist/content.js"],
    "run_at": "document_idle"
  }],

  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
