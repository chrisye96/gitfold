{
  "name": "gitfold",
  "version": "0.1.0",
  "description": "Download any GitHub directory as a zip — instantly",
  "private": true,
  "workspaces": [
    "worker",
    "cli"
  ],
  "scripts": {
    "dev:worker": "pnpm --filter worker dev",
    "dev:web": "serve web",
    "build:worker": "pnpm --filter worker build",
    "deploy:worker": "pnpm --filter worker deploy",
    "deploy:web": "echo 'Deploy web/ to Cloudflare Pages via git push'",
    "copy-vendors": "node -e \"const fs=require('fs');fs.mkdirSync('web/vendor',{recursive:true});fs.copyFileSync('node_modules/jszip/dist/jszip.min.js','web/vendor/jszip.min.js');console.log('vendors copied')\""
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "jszip": "^3.10.1",
    "serve": "^14.2.6"
  }
}
